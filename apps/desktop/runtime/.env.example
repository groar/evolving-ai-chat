# Runtime environment variables
# Copy this file to .env and fill in real values. Never commit .env to version control.

# ─── Chat / model provider keys ───────────────────────────────────────────────
# At least one is required for the chat feature.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── M8 Agent Harness (T-0059) ────────────────────────────────────────────────
# pi (https://pi.dev) is the default harness: npm install -g @mariozechner/pi-coding-agent
#
# PATCH_AGENT_API_KEY
#   API key forwarded to pi via --api-key. Can be the same Anthropic/OpenAI key
#   used for chat, or a separate key dedicated to code-patch runs.
#   When absent, the agent falls back to stub mode (no real changes generated).
PATCH_AGENT_API_KEY=sk-ant-...

# PATCH_AGENT_PROVIDER  (default: anthropic)
#   The LLM provider pi should use (anthropic | openai | google | etc.).
#   Must match the provider for PATCH_AGENT_API_KEY.
# PATCH_AGENT_PROVIDER=anthropic

# PATCH_AGENT_MODEL  (default: pi's configured default)
#   Optional model override for pi. Recommended for self-evolving runs: openai/gpt-5.3-codex.
#   Example: PATCH_AGENT_MODEL=openai/gpt-5.3-codex with PATCH_AGENT_PROVIDER=openai.
# PATCH_AGENT_MODEL=openai/gpt-5.3-codex

# PATCH_AGENT_STUB  (default: unset)
#   Set to "true" to force stub mode regardless of API key.
#   Useful for CI or offline development.
# PATCH_AGENT_STUB=true

# ─── Apply pipeline timeouts (T-0095) ────────────────────────────────────────
# Optional. Defaults: 300s each. Increase if Fix with AI runs hit timeout before commit.
# APPLY_PATCH_TIMEOUT_SEC=300   # patch command (apply diff)
# APPLY_VALIDATE_TIMEOUT_SEC=300   # npm run validate in sandbox

# ─── Storage paths (optional overrides) ───────────────────────────────────────
# RUNTIME_DB_PATH=/path/to/runtime.db
# RUNTIME_PATCH_STORAGE_DIR=/path/to/patches  # Patch artifact JSON files
